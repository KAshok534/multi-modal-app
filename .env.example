# Environment variables for Chorus.
# In production (Vercel), add these in Project → Settings → Environment Variables.
# Locally you can keep using keys.txt instead — env vars override it.
#
# Find the values in your local keys.txt (the part after the first "|").
# DO NOT commit real values — this .example file ships with blanks on purpose.

# Required — the only working provider; powers every model in the app.
OPENROUTER_API_KEY=

# Optional direct-provider keys (currently inactive on the bundled account,
# but wired in — set one and its models go Online automatically).
DEEPSEEK_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
QWEN_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
GEMINI_API_KEY=

# STRONGLY RECOMMENDED for a public deployment.
# When set, the app is locked behind this shared password so a stranger with
# the URL can't run up charges on your API keys. Leave blank = open to anyone.
ACCESS_PASSWORD=
